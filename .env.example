# ===== Supabase Auth =====
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# ===== AI Provider (Groq) =====
# Default backend AI provider used by the codebase is Groq (configured in `backend/config.py`).
# Set this to your Groq API key to enable the AI features used by the app.
GROQ_API_KEY=your_groq_api_key

# Optional: If you prefer to call Google Gemini directly, you may set this key.
# The current backend does not automatically fall back to Gemini; you would need
# to update `backend/services/ai_service.py` to use this key and the Gemini SDK.
# GEMINI_API_KEY=your_gemini_api_key

# ===== Database =====
# SQLite (default for local dev — no change needed)
DATABASE_URL=sqlite:///./learning_companion.db
# PostgreSQL (production — uncomment and fill in)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== Redis (Optional) =====
REDIS_URL=redis://localhost:6379

# ===== App Settings =====
SECRET_KEY=change_this_to_a_random_secret_string
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
